<robot name="spot">
  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="link_models/base.obj"/>
      </geometry>
<material name="base"> <color rgba="1 0.8431 0 1"/></material>    </visual>
  </link>
